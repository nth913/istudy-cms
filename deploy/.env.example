# === Database ===
DATABASE_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/istudy

# === Payload core ===
PAYLOAD_SECRET=<64-char-hex>
PAYLOAD_PUBLIC_SERVER_URL=https://cms.aistudy.com.vn

# === Storage R2 ===
S3_ACCESS_KEY_ID=<r2-access-key>
S3_SECRET_ACCESS_KEY=<r2-secret-key>
S3_BUCKET=istudy-media
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_REGION=auto

# === Webhook to FE ===
REVALIDATE_SECRET=<32-char-hex>
FE_URL=https://aistudy.com.vn

# === Anon cookie HMAC ===
ANON_COOKIE_SECRET=<32-char-hex>

# === Email ===
RESEND_API_KEY=re_<token>
RESEND_AUDIENCE_ID=<audience-id>

# === Monitoring ===
SENTRY_DSN=https://<key>@sentry.io/<project>
SENTRY_ENVIRONMENT=production

# === Runtime ===
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_VERSION=<set-at-build-time>
