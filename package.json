{
  "name": "istudy-cms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x",
    "pnpm": "9.x"
  },
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 3131",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev -p 3131",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start -p 3131",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ./vitest.config.mts",
    "test:watch": "vitest --config ./vitest.config.mts",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "seed": "tsx scripts/seed/index.ts",
    "seed:event-2026-05-24": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=4096\" tsx scripts/seed/event-2026-05-24.ts",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "watch:imports": "tsx scripts/folder-watch/index.ts",
    "docker:build": "docker build -f deploy/Dockerfile -t istudy-cms:local .",
    "docker:run": "docker run --rm -p 3000:3000 --env-file .env.local istudy-cms:local"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@payloadcms/db-mongodb": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@payloadcms/storage-s3": "^3.84.1",
    "@payloadcms/ui": "^3.84.1",
    "@sentry/nextjs": "^8.0.0",
    "chokidar": "^5.0.0",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "next": "^15.5.0",
    "papaparse": "^5.5.3",
    "payload": "^3.84.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.12.3",
    "sharp": "0.32.6",
    "slugify": "^1.6.9"
  },
  "devDependencies": {
    "@types/node": "20.14.0",
    "@types/papaparse": "^5.5.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.0.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.0",
    "typescript": "5.5.3",
    "vitest": "^2.0.0"
  }
}
