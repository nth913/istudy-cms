# === Database ===
DATABASE_URL=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/istudy?retryWrites=true&w=majority

# === Payload core ===
PAYLOAD_SECRET=                # 64-char hex random
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3131

# === Storage R2 ===
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET_PUBLIC=istudy-media-public
S3_BUCKET_PRIVATE=istudy-media-private
S3_BUCKET_BACKUPS=istudy-backups
S3_REGION=auto
S3_PUBLIC_URL=https://cdn.aistudy.com.vn

# === Webhook to FE ===
REVALIDATE_SECRET=             # 32-char hex
FE_URL=http://localhost:3000

# === Anon cookie HMAC ===
ANON_COOKIE_SECRET=            # 32-char hex

# === Email ===
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# === Monitoring ===
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
